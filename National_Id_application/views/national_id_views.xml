<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_national_id" model="ir.sequence">
        <field name="name">National ID Application Sequence</field>
        <field name="code">national.id.seq</field>
        <field name="padding">6</field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_national_id_list" model="ir.ui.view">
        <field name="name">national.id.list</field>
        <field name="model">national.id</field>
        <field name="arch" type="xml">
            <list string="National ID Applications">
                <field name="id_number" string="App ID"/>
                <field name="full_name" string="Applicant Name"/>
                <field name="sex"/>
                <field name="date_of_birth"/>
                <field name="district"/>
                <field name="mobile_number"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'submitted'"
                    decoration-warning="state in ['stage1','stage2']"
                    decoration-success="state == 'approved'"
                    decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW — no oe_chatter div at all -->
    <record id="view_national_id_form" model="ir.ui.view">
        <field name="name">national.id.form</field>
        <field name="model">national.id</field>
        <field name="arch" type="xml">
            <form string="National ID Application">
                <header>
                    <!-- Stage 1 Verifier only, when submitted -->
                    <button name="action_verify_documents"
                            string="Stage 1: Verify and Approve"
                            type="object"
                            class="btn-warning"
                            invisible="state != 'submitted'"
                            groups="National_Id_application.group_nira_stage1"/>

                    <!-- Stage 2 Approver only, when at stage2 -->
                    <button name="action_final_approve"
                            string="Stage 2: Final Approve"
                            type="object"
                            class="btn-success"
                            invisible="state != 'stage2'"
                            groups="National_Id_application.group_nira_stage2"/>

                    <!-- Reject: Stage 1 and above, not on approved/rejected -->
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            invisible="state in ['approved', 'rejected']"
                            groups="National_Id_application.group_nira_stage1"/>

                    <!-- Reset: Manager only, on rejected records -->
                    <button name="action_reset_to_draft"
                            string="Reset to Submitted"
                            type="object"
                            invisible="state != 'rejected'"
                            groups="National_Id_application.group_nira_manager"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="submitted,stage1,stage2,approved"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="full_name" readonly="1"/></h1>
                        <h4><field name="id_number" readonly="1"/></h4>
                    </div>

                    <field name="applicant_photo" widget="image"
                           class="oe_avatar" options="{'size': [128, 128]}"/>

                    <group>
                        <group string="Personal Information">
                            <field name="surname"/>
                            <field name="given_name"/>
                            <field name="date_of_birth"/>
                            <field name="sex"/>
                            <field name="citizenship_type"/>
                            <field name="mobile_number"/>
                        </group>
                        <group string="Address and Origin">
                            <field name="district"/>
                            <field name="village"/>
                        </group>
                    </group>

                    <group string="Documents">
                        <field name="lc_letter"
                               filename="lc_letter_filename"
                               string="LC Reference Letter"/>
                        <field name="lc_letter_filename" invisible="1"/>
                        <button name="action_view_lc_letter"
                                string="Open / View LC Letter"
                                type="object"
                                class="btn btn-sm btn-outline-primary"
                                invisible="not lc_letter"/>
                    </group>

                    <group string="Rejection Reason"
                           invisible="state != 'rejected'">
                        <field name="rejection_reason" readonly="1" nolabel="1"/>
                    </group>

                    <!-- Clean approval history — replaces chatter entirely -->
                    <group string="Approval History">
                        <field name="approval_log"
                               readonly="1"
                               nolabel="1"
                               style="white-space: pre-wrap;
                                      font-family: monospace;
                                      font-size: 13px;
                                      background: #f8f9fa;
                                      padding: 10px;
                                      border-radius: 4px;
                                      display: block;
                                      min-height: 50px;
                                      width: 100%;"/>
                    </group>

                </sheet>
                <!-- NO oe_chatter div — this is what was causing the layout
                     push and the noisy mail log table -->
            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_national_id_search" model="ir.ui.view">
        <field name="name">national.id.search</field>
        <field name="model">national.id</field>
        <field name="arch" type="xml">
            <search>
                <field name="full_name"/>
                <field name="id_number"/>
                <field name="district"/>
                <field name="mobile_number"/>
                <filter name="submitted" string="Pending"
                        domain="[('state','=','submitted')]"/>
                <filter name="stage2" string="Awaiting Final Approval"
                        domain="[('state','=','stage2')]"/>
                <filter name="approved" string="Approved"
                        domain="[('state','=','approved')]"/>
                <filter name="rejected" string="Rejected"
                        domain="[('state','=','rejected')]"/>
                <filter name="group_state" string="Group by Status"
                        context="{'group_by': 'state'}"/>
                <filter name="group_district" string="Group by District"
                        context="{'group_by': 'district'}"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_national_id_application" model="ir.actions.act_window">
        <field name="name">National ID Applications</field>
        <field name="res_model">national.id</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_national_id_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No applications yet.
            </p>
        </field>
    </record>

</odoo>
