<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="apply_form_template" name="National ID Application Form">
        <t t-call="website.layout">
            <div class="container mt-5 mb-5" style="max-width:780px;">

                <div class="text-center mb-4">
                    <h2 class="fw-bold">National ID Application Form</h2>
                    <p class="text-muted">Fill in all required fields and attach your documents</p>
                </div>

                <form action="/apply_national_id" method="post" enctype="multipart/form-data" class="card p-4 shadow-sm">

                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- PERSONAL INFORMATION -->
                    <h5 class="mb-3 border-bottom pb-2">Personal Information</h5>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Surname <span class="text-danger">*</span></label>
                            <input type="text" name="surname" class="form-control" required="required" placeholder="Enter surname"/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Given Name <span class="text-danger">*</span></label>
                            <input type="text" name="given_name" class="form-control" required="required" placeholder="Enter given name"/>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Date of Birth <span class="text-danger">*</span></label>
                            <input type="date" name="date_of_birth" class="form-control" required="required"/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Sex <span class="text-danger">*</span></label>
                            <select name="sex" class="form-select" required="required">
                                <option value="">-- Select --</option>
                                <option value="male">Male</option>
                                <option value="female">Female</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Citizenship <span class="text-danger">*</span></label>
                            <select name="citizenship_type" class="form-select" required="required">
                                <option value="birth">By Birth</option>
                                <option value="registration">By Registration</option>
                                <option value="naturalisation">By Naturalisation</option>
                                <option value="dual">Dual Citizen</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Mobile Number <span class="text-danger">*</span></label>
                            <input type="tel" name="mobile_number" class="form-control" required="required" placeholder="+256 700 000000"/>
                            <small class="text-muted">You will receive an SMS when your application is approved</small>
                        </div>
                    </div>

                    <!-- ADDRESS -->
                    <h5 class="mb-3 border-bottom pb-2 mt-4">Address</h5>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">District <span class="text-danger">*</span></label>
                            <input type="text" name="district" class="form-control" required="required" placeholder="e.g. Kampala"/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Village <span class="text-danger">*</span></label>
                            <input type="text" name="village" class="form-control" required="required" placeholder="Enter village"/>
                        </div>
                    </div>

                    <!-- NOTIFICATION -->
                    <h5 class="mb-3 border-bottom pb-2 mt-4">Notification Preferences</h5>
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label">Email Address <span class="text-muted">(optional – for approval notification)</span></label>
                            <input type="email" name="email" class="form-control" placeholder="e.g. yourname@email.com"/>
                            <small class="text-muted">If provided, you will also receive an email when your application is approved</small>
                        </div>
                    </div>

                    <!-- DOCUMENTS -->
                    <h5 class="mb-3 border-bottom pb-2 mt-4">Documents</h5>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Passport Photo <span class="text-danger">*</span></label>
                            <input type="file" name="applicant_photo" class="form-control" accept="image/*" required="required"/>
                            <small class="text-muted">Upload a clear passport-size photo (JPG or PNG)</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">LC Reference Letter <span class="text-danger">*</span></label>
                            <input type="file" name="lc_letter" class="form-control" accept=".pdf,.jpg,.png" required="required"/>
                            <small class="text-muted">Upload your LC reference letter (PDF or image)</small>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <button type="submit" class="btn btn-primary btn-lg px-5">
                            Submit Application
                        </button>
                    </div>

                </form>
            </div>
        </t>
    </template>

    <!-- THANK YOU PAGE -->
    <template id="thanks_template" name="Application Submitted">
        <t t-call="website.layout">
            <div class="container mt-5 text-center">
                <div class="card p-5 shadow-sm">
                    <h2 class="text-success fw-bold">&#10003; Application Submitted Successfully!</h2>
                    <p class="mt-3 fs-5">Thank you, <strong t-esc="name"/></p>
                    <p>Your application reference number is:</p>
                    <h3 class="text-primary fw-bold" t-esc="application_id"/>
                    <p class="text-muted mt-3">
                        Please keep this reference number safe.<br/>
                        You will receive an <strong>SMS</strong> (and email if provided) once your application is approved.
                    </p>
                    <a href="/apply_national_id" class="btn btn-outline-primary mt-3">Submit Another Application</a>
                </div>
            </div>
        </t>
    </template>

</odoo>
